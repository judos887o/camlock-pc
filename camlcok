local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local camera = workspace.CurrentCamera

local localPlayer = Players.LocalPlayer

if getgenv().Camlock_Destroy then pcall(getgenv().Camlock_Destroy) end
local Connections = {}

local fovRadius = 1200
local maxPrediction = 0.2
local minSpeedForPrediction = 5

local isAiming = false
local targetCharacter = nil
local targetPlayer = nil
local AimKey = Enum.KeyCode.Q

local LastPositions = {}
local LastTimes = {}
local LastVelocities = {}
local LastRawVelocities = {}
local MyLastPosition = nil
local MyLastTime = nil
local MyVelocity = Vector3.zero
local currentAimCF = nil

local gui = Instance.new("ScreenGui")
gui.Name = "CamlockGUI"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true
gui.Parent = localPlayer:WaitForChild("PlayerGui")

local container = Instance.new("Frame", gui)
container.Size = UDim2.new(0, 340, 0, 52)
container.Position = UDim2.new(0.5, -170, 0.82, 0)
container.BackgroundTransparency = 1

local keyBox = Instance.new("TextBox", container)
keyBox.Size = UDim2.new(0, 52, 0, 52)
keyBox.Position = UDim2.new(0, 0, 0, 0)
keyBox.BackgroundTransparency = 0.25
keyBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
keyBox.Text = "Q"
keyBox.Font = Enum.Font.GothamBold
keyBox.TextColor3 = Color3.fromRGB(255, 255, 255)
keyBox.TextSize = 20
keyBox.ClearTextOnFocus = true
keyBox.PlaceholderText = "..."
keyBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
Instance.new("UICorner", keyBox).CornerRadius = UDim.new(0, 10)
local keyStroke = Instance.new("UIStroke", keyBox)
keyStroke.Color = Color3.fromRGB(80, 80, 80)
keyStroke.Thickness = 1.5

local label = Instance.new("TextLabel", container)
label.Size = UDim2.new(0, 280, 0, 52)
label.Position = UDim2.new(0, 60, 0, 0)
label.BackgroundTransparency = 0.25
label.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
label.Text = "Cam Lock | Ready"
label.Font = Enum.Font.GothamBold
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.TextSize = 17
label.TextStrokeTransparency = 0.7
Instance.new("UICorner", label).CornerRadius = UDim.new(0, 10)

keyBox.FocusLost:Connect(function()
    local input = keyBox.Text:upper():gsub("%s", "")
    if input == "" then
        keyBox.Text = AimKey.Name
        return
    end
    local success, key = pcall(function() return Enum.KeyCode[input] end)
    if success and key then
        AimKey = key
        keyBox.Text = key.Name
        keyStroke.Color = Color3.fromRGB(0, 255, 80)
        task.delay(0.5, function() keyStroke.Color = Color3.fromRGB(80, 80, 80) end)
    else
        keyBox.Text = AimKey.Name
        keyStroke.Color = Color3.fromRGB(255, 50, 50)
        task.delay(0.5, function() keyStroke.Color = Color3.fromRGB(80, 80, 80) end)
    end
end)

local function updateGui()
    if isAiming and targetPlayer then
        label.Text = "LOCKED → " .. targetPlayer.DisplayName
        label.TextColor3 = Color3.fromRGB(0, 255, 80)
    else
        label.Text = "Cam Lock | Ready"
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

local function UpdateMyVelocity()
    local myChar = localPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then MyVelocity = Vector3.zero return end

    local now = tick()
    if MyLastPosition and MyLastTime then
        local dt = now - MyLastTime
        if dt > 0 and dt < 0.5 then
            local raw = (myRoot.Position - MyLastPosition) / dt
            MyVelocity = MyVelocity:Lerp(raw, 0.5)
        end
    end
    MyLastPosition = myRoot.Position
    MyLastTime = now
end

local function GetAdaptiveVelocity(char)
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return Vector3.zero, false end

    local now = tick()
    local id = char:GetDebugId()
    local isAntiLock = false

    if LastPositions[id] and LastTimes[id] then
        local dt = now - LastTimes[id]
        if dt > 0 and dt < 0.5 then
            local rawVel = (root.Position - LastPositions[id]) / dt
            local lastRaw = LastRawVelocities[id] or rawVel

            local dirChange = (rawVel - lastRaw).Magnitude
            local speed = rawVel.Magnitude

            local smoothFactor = 0.45
            if dirChange > 40 or speed > 70 then
                smoothFactor = 0.65
                isAntiLock = true
            elseif dirChange > 20 then
                smoothFactor = 0.55
                isAntiLock = true
            end

            local old = LastVelocities[id] or rawVel
            local smooth = old:Lerp(rawVel, smoothFactor)

            LastVelocities[id] = smooth
            LastRawVelocities[id] = rawVel
            LastPositions[id] = root.Position
            LastTimes[id] = now

            return smooth, isAntiLock
        end
    end

    LastPositions[id] = root.Position
    LastTimes[id] = now
    LastVelocities[id] = root.Velocity
    LastRawVelocities[id] = root.Velocity
    return root.Velocity, false
end

local function GetPing()
    local ping = 0.06
    local np = localPlayer:FindFirstChild("NetworkPing")
    if np then ping = np.Value or 0.06 end
    return ping
end

local function IsCharacterValid(char)
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

local function getClosestTarget()
    local closestTarget, closestPlayer = nil, nil
    local shortestDistance = fovRadius
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        closestTarget = plr.Character
                        closestPlayer = plr
                    end
                end
            end
        end
    end
    return closestTarget, closestPlayer
end

local function getAverageHitboxPosition(char)
    local parts = {}
    for _, partName in ipairs({ "Head", "UpperTorso", "HumanoidRootPart" }) do
        local part = char:FindFirstChild(partName)
        if part then table.insert(parts, part.Position) end
    end
    if #parts == 0 then return nil end
    local sum = Vector3.new(0, 0, 0)
    for _, pos in ipairs(parts) do sum += pos end
    return sum / #parts
end

local function getPredictedPosition(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, false end

    local avgPos = getAverageHitboxPosition(char)
    if not avgPos then return nil, false end

    local targetVel, antiLock = GetAdaptiveVelocity(char)

    local relativeVel = targetVel - MyVelocity
    local relSpeed = relativeVel.Magnitude

    if relSpeed < minSpeedForPrediction then
        return avgPos, false
    end

    local ping = GetPing()
    local speedFactor = math.clamp((relSpeed - minSpeedForPrediction) / 15, 0, 1)
    local dynamicPrediction = math.clamp(relSpeed / 50, 0, maxPrediction) + (ping * 0.5)
    dynamicPrediction = dynamicPrediction * speedFactor

    if antiLock then
        dynamicPrediction = dynamicPrediction * 0.5
    end

    return avgPos + (relativeVel * dynamicPrediction), antiLock
end

table.insert(Connections, UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if keyBox:IsFocused() then return end
    if input.KeyCode == AimKey then
        if isAiming then
            isAiming = false
            targetCharacter = nil
            targetPlayer = nil
            currentAimCF = nil
        else
            local target, plr = getClosestTarget()
            if target then
                isAiming = true
                targetCharacter = target
                targetPlayer = plr
                currentAimCF = camera.CFrame
            end
        end
        updateGui()
    end
end))

table.insert(Connections, RunService.Heartbeat:Connect(function()
    UpdateMyVelocity()

    if isAiming then
        if not IsCharacterValid(targetCharacter) then
            task.wait(0.25)
            if not IsCharacterValid(targetCharacter) then
                if targetPlayer and targetPlayer.Character and IsCharacterValid(targetPlayer.Character) then
                    targetCharacter = targetPlayer.Character
                else
                    local newT, newP = getClosestTarget()
                    if newT then
                        targetCharacter = newT
                        targetPlayer = newP
                        updateGui()
                    else
                        isAiming = false
                        targetCharacter = nil
                        targetPlayer = nil
                        currentAimCF = nil
                        updateGui()
                    end
                end
            end
        end
    end
end))

table.insert(Connections, RunService.RenderStepped:Connect(function(dt)
    if isAiming and IsCharacterValid(targetCharacter) then
        local predictedPos, antiLock = getPredictedPosition(targetCharacter)
        if predictedPos then
            local currentCF = camera.CFrame
            local targetCF = CFrame.new(currentCF.Position, predictedPos)

            local speed = antiLock and 14 or 8
            local alpha = 1 - math.exp(-speed * dt)

            if not currentAimCF then
                currentAimCF = currentCF
            end

            currentAimCF = currentAimCF:Lerp(targetCF, alpha)
            camera.CFrame = CFrame.new(currentCF.Position) * (currentAimCF - currentAimCF.Position)
        end
    else
        if isAiming then
            isAiming = false
            targetCharacter = nil
            targetPlayer = nil
            currentAimCF = nil
            updateGui()
        end
    end
end))

updateGui()

getgenv().Camlock_Destroy = function()
    for _, c in pairs(Connections) do
        pcall(function() c:Disconnect() end)
    end
    if gui then gui:Destroy() end
    isAiming = false
    getgenv().Camlock_Destroy = nil
end
